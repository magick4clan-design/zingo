# Backend
NODE_ENV=production
PORT=5000
DATABASE_URL=file:/data/dev.db

# CORS
CORS_ORIGINS=https://*.vercel.app,http://localhost:3000,http://localhost:3001

# JWT
JWT_SECRET=change-this-to-a-strong-random-string
JWT_EXPIRES_IN=30d

# Scraper
SCRAPER_API_KEY=change-this-to-a-strong-random-string
SCRAPER_INTERVAL_HOURS=12

# Email (optional)
EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=Zingo <onboarding@resend.dev>

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
